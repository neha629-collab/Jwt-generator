{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/public/token",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/public/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/token",
      "destination": "/api/index.py"
    },
    {
      "source": "/access-jwt",
      "destination": "/api/index.py"
    }
  ]
}
